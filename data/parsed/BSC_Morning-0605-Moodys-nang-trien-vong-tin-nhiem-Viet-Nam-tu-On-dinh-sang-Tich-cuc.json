ist":[{"block_label":"header_image","block_content":"<div style=\"text-align: center;\"></div>\n","block_bbox":[27,24,176,119],"block_id":0,"group_id":0,"block_polygon_points":[[27.0,24.0],[176.0,24.0],[176.0,119.0],[27.0,119.0]]},{"block_label":"header","block_content":"BẢN TIN SÁNG NGÀY 05/05/2026","block_bbox":[205,41,935,97],"block_id":1,"group_id":1,"block_polygon_points":[[205.0,41.0],[935.0,41.0],[935.0,97.0],[205.0,97.0]]},{"block_label":"paragraph_title","block_content":"## Khuyến cáo sử dụng","block_bbox":[348,180,729,226],"block_id":2,"block_order":1,"group_id":2,"block_polygon_points":[[348.0,180.0],[729.0,180.0],[729.0,226.0],[348.0,226.0]]},{"block_label":"text","block_content":"Bản báo cáo này của Công ty Cổ phần Chúng khoán BIDV (BSC), chỉ cung cấp những thông tin chung và phần tích về tình hình kinh tế vĩ mô cũng như diễn biến thị trường chúng khoán. Báo cáo này không được xây dựng để cung cấp theo yêu cầu của bất kỳ tổ chức hay cá nhân riêng lẻ nào hoặc các quyết định mua bán, nằm giữ chứng khoán. Nhà đầu tư chỉ nên sử dụng các thông tin, phân tích, bình luận của Bản báo cáo như là nguồn tham khảo trước khi đưa ra những quyết định đầu tư cho riêng mình. Mọi thông tin, nhận định và dự báo và quan điểm trong báo cáo này được dựa trên những nguồn dữ liệu đáng tin cậy. Tuy nhiên BSC không đảm bảo rằng các nguồn thông tin này là hoàn toàn chính xác và không chịu bất kỳ một trách nhiệm nào đối với tính chính xác của những thông tin được để cấp đến trong báo cáo này, cũng như không chịu trách nhiệm về những thiệt hại đối với việc sử dụng toàn bộ hay một phần nội dung của bản báo cáo này. Mọi quan điểm cũng như nhận định được để cấp trong báo cáo này dựa trên sự cần nhắc cấn trọng, công minh và hợp lý nhất trong hiện tại. Tuy nhiên những quan điểm, nhận định này có thể thay đổi mà không cần báo trước. Bản báo cáo này có bản quyền và là tài sản của BSC. Mọi hành vi sao chép, sửa đổi, in ấn mà không có sự đồng ý của BSC đều trái luật. Bất kỳ nội dung nào của tài liệu này cũng không được (i) sao chụp hay nhân bản ở bất kỳ hình thức hay phương thức nào hoặc (ii) được cung cấp nếu không được sự chấp thuận của BSC.","block_bbox":[38,245,1042,610],"block_id":3,"block_order":2,"group_id":3,"block_polygon_points":[[38.0,245.0],[1042.0,245.0],[1042.0,610.0],[38.0,610.0]]},{"block_label":"text","block_content":"© 2026 BIDV Securities Company, All rights reserved. Unauthorized access is prohibited.","block_bbox":[39,640,765,665],"block_id":4,"block_order":3,"group_id":4,"block_polygon_points":[[39.0,640.0],[765.0,640.0],[765.0,665.0],[39.0,665.0]]},{"block_label":"paragraph_title","block_content":"#### Thông tin liên hệ - Trung tâm Phân tích Nghiên cứu","block_bbox":[39,717,514,745],"block_id":5,"block_order":4,"group_id":5,"block_polygon_points":[[39.0,717.0],[514.0,717.0],[514.0,745.0],[39.0,745.0]]},{"block_label":"text","block_content":"Bùi Nguyên Khoa\n\nPGĐ Trung tâm Phân tích Nghiên cứu\n\nVĩ mô – Thị trường\n\nKhoabn@bsc.com.vn\n\nPhan Quốc Bửu\n\nPGĐ Trung tâm Phân tích Nghiên cứu\n\nNgành – Doanh nghiệp\n\nBuupq@bsc.com.vn","block_bbox":[38,859,322,947],"block_id":6,"block_order":5,"group_id":6,"block_polygon_points":[[38.0,859.0],[322.0,859.0],[322.0,947.0],[38.0,947.0]]},{"block_label":"text","block_content":"","block_bbox":[391,860,674,950],"block_id":7,"block_order":6,"group_id":6,"block_polygon_points":[[391.0,860.0],[674.0,860.0],[674.0,950.0],[391.0,950.0]]},{"block_label":"paragraph_title","block_content":"##### Nhóm Vĩ mô – Thị trường","block_bbox":[40,983,261,1006],"block_id":8,"block_order":7,"group_id":8,"block_polygon_points":[[40.0,983.0],[261.0,983.0],[261.0,1006.0],[40.0,1006.0]]},{"block_label":"text","block_content":"Vũ Việt Anh\n\nChuyên viên phân tích\n\nAnhwv@bsc.com.vn","block_bbox":[40,1014,211,1080],"block_id":9,"block_order":8,"group_id":9,"block_polygon_points":[[40.0,1014.0],[211.0,1014.0],[211.0,1080.0],[40.0,1080.0]]},{"block_label":"text","block_content":"Trần Thanh Tùng\n\nChuyên viên phâ