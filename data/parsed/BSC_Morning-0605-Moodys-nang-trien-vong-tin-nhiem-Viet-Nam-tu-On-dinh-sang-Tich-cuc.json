block_polygon_points":[[10.0,331.0],[629.0,331.0],[629.0,380.0],[10.0,380.0]]},{"block_label":"text","block_content":"Hoa Kỳ: Bộ trưởng Quốc phòng Hegseth cho biết lệnh ngừng bắn với lran chưa kết thúc.","block_bbox":[10,390,630,440],"block_id":6,"block_order":6,"group_id":6,"block_polygon_points":[[10.0,390.0],[630.0,390.0],[630.0,440.0],[10.0,440.0]]},{"block_label":"text","block_content":"Iran: Công bố bản đồ vùng kiểm soát hàng hải mới bao trùm eo biển Hormuz, đồng thời cảnh báo sẽ tấn công nếu lực lượng Mỹ hoặc nước ngoài can thiệp.","block_bbox":[9,449,631,524],"block_id":7,"block_order":7,"group_id":7,"block_polygon_points":[[9.0,449.0],[631.0,449.0],[631.0,524.0],[9.0,524.0]]},{"block_label":"text","block_content":"Việt Nam: Moody's nâng triển vọng tín nhiệm Việt Nam từ \"Ổn định\" sang \"Tích cực\" và xếp hạng tín nhiệm quốc gia của Việt Nam ở mức Ba2.","block_bbox":[10,532,630,605],"block_id":8,"block_order":8,"group_id":8,"block_polygon_points":[[10.0,532.0],[630.0,532.0],[630.0,605.0],[10.0,605.0]]},{"block_label":"text","block_content":"Việt Nam: 4T2026, tiến độ giải ngân vốn đầu tư công vấn chậm khi có tới 14 đơn vị gần như chưa triển khai giải ngân hoặc tỷ lệ dưới 1%. Tình trạng \"vốn chờ dự án\" vẫn phổ biến, khi nhiều đơn vị được giao nguồn lực lớn nhưng giải ngân ở mức rất thấp do dự án chưa đủ điều kiện triển khai.","block_bbox":[9,616,630,737],"block_id":9,"block_order":9,"group_id":9,"block_polygon_points":[[9.0,616.0],[630.0,616.0],[630.0,737.0],[9.0,737.0]]},{"block_label":"text","block_content":"Việt Nam: NHNN đang lấy ý kiến dự thảo Thông tư thay thế Thông tư số 22/2019/TT-NHNN quy định các giới hạn, tỷ lệ bảo đảm an toàn trong hoạt động của ngân hàng, với nhiều thay đổi lớn trong khung an toàn hệ thống.","block_bbox":[10,747,631,844],"block_id":10,"block_order":10,"group_id":10,"block_polygon_points":[[10.0,747.0],[631.0,747.0],[631.0,844.0],[10.0,844.0]]},{"block_label":"paragraph_title","block_content":"#### Tin tức thị trường","block_bbox":[16,877,231,907],"block_id":11,"block_order":11,"group_id":11,"block_polygon_points":[[16.0,877.0],[231.0,877.0],[231.0,907.0],[16.0,907.0]]},{"block_label":"text","block_content":"Việt Nam: VN-Index tiếp tục rung lắc mạnh tại vùng giá cao và thanh khoản thấp, khuyến nghị nhà đầu tư tiếp tục giao dịch theo biến động ngắn hạn của thị trường.","block_bbox":[13,917,622,990],"block_id":12,"block_order":12,"group_id":12,"block_polygon_points":[[13.0,917.0],[622.0,917.0],[622.0,990.0],[13.0,990.0]]},{"block_label":"text","block_content":"- PLX: Quý 1, doanh thu thuần đạt gần 98.7 nghìn tỷ đồng, tăng 45% y/y. Chi phí trong kỳ tăng khiến PLX lỗ ròng 763 tỷ đồng (cùng kỳ lãi 133 tỷ đồng).","block_bbox":[14,997,622,1068],"block_id":13,"block_order":13,"group_id":13,"block_polygon_points":[[14.0,997.0],[622.0,997.0],[622.0,1068.0],[14.0,1068.0]]},{"block_label":"text","block_content":"• VPI: Quý 1, doanh thu thuần hơn 287 tỷ đồng, tăng 16% y/y. Động lực chính đến từ hoạt động chuyển nhượng bất động sản tăng 15% lên gần 210 tỷ đồng. Lợi nhuận ròng đạt gần 27 tỷ đồng, giảm 81% y/y.","block_bbox":[13,1076,622,1149],"block_id":14,"block_order":14,"group_id":14,"block_polygon_points":[[13.0,1076.0],[622.0,1076.0],[622.0,1149.0],[13.0,1149.0]]},{"block_label":"text","block_content":"SGN: Quý 1, doanh thu thuần gần 390 tỷ đồng và lợi nhuận ròng 65 tỷ đồng, giảm lẫn lượt 7% và gần 10% y/y.","block_bbox":[13,1155,622,1204],"block_id":15,"block_order":15,"group_id":15,"block_polygon_points":[[13.0,1155.0],[622.0,1155.0],[622.0,1204.0],[13.0,1204.0]]},{"block_label":"text","block_content":"AGG: Quý 1, doanh thu thuần hợp nhất đạt 67.3 tỷ đồng, giảm 65% y/y. Lợi nhuận sau thuế đạt hơn 5 tỷ đồng, giảm 38% y/y.","block_bbox":[14,1211,621,1260],"block_id":16,"block_order":16,"group_id":16,"block_polygon_points":[[14.0,1211.0],[621.0,1211.0],[621.0,1260.0],[14.0,1260.0]]},{"block_label":"text","block_content":"• VNZ: Quý 1, doanh thu đạt 2.8 nghìn tỷ đồng, +32% y/y; lãi ròng hơn 182 tỷ đồng, đảo chiều so với khoản lỗ 4.8 tỷ đồng cùng kỳ.","block_bbox":[14,1266,622,1315],"block_id":17,"block_order":17,"group_id":17,"block_polygon_points":[[14.0,1266.0],[622.0,1266.0],[622.0,1315.0],[14.0,1315.0]]},{"block_label":"text","block_content":"NKG: Quý 1, doanh thu thuần gần 3.3 ngàn tỷ đồng và lãi ròng hơn 22 tỷ đồng, giảm tương ứng 20% và 66% y/y.","block_bbox":[14,1322,622,1370],"block_id":18,"block_order":18,"group_id":18,"block_polygon_points":[[14.0,1322.0],[622.0,1322.0],[622.0,1370.0],[14.0,1370.0]]},{"block_label":"text","block_content":"- HAH: Quý 1, doanh thu thuần tăng 8% lên 1.26 ngàn tỷ đồng, trong khi lợi nhuận ròng tăng đến 29% lên 300 tỷ đồng.","block_bbox":[14,1377,622,1426],"block_id":19,"block_order":19,"group_id":19,"block_polygon_points":[[14.0,1377.0],[622.0,1377.0],[622.0,1426.0],[14.0,1426.0]]},{"block_label":"text","block_content":"VNX: Ghi nhận kết quả kinh doanh ăn tương, với doanh thu và lợi nhuận đều tăng trên 80% so với cùng kỳ, thực hiện được 26% kế hoạch cả năm.","block_bbox":[13,1433,623,1503],"block_id":20,"block_order":20,"group_id":20,"block_polygon_points":[[13.0,1433.0],[623.0,1433.0],[623.0,1503.0],[13.0,1503.0]]},{"block_label":"paragraph_title","block_content":"### Thị trường tài chính","block_bbox":[670,169,914,203],"block_id":21,"block_order":21,"group_id":21,"block_polygon_points":[[670.0,169.0],[914.0,169.0],[914.0,203.0],[670.0,203.0]]},{"block_label":"table","block_content":"\n\n<table border=1 style='margin: auto; word-wrap: break-word;'><tr><td style='text-align: center; word-wrap: break-word;'></td><td style='text-align: center; word-wrap: break-word;'>06/05/2026</td><td style='text-align: center; word-wrap: break-word;'>%Ngày</td></tr><tr><td colspan=\"3\">Thị trường chúng khoản</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>S&amp;P500</td><td style='text-align: center; word-wrap: break-word;'>7,259.2</td><td style='text-align: center; word-wrap: break-word;'>+0.81</td></tr><tr><td style