[{"prunedResult":{"model_settings":{"use_doc_preprocessor":false,"use_layout_detection":true,"use_chart_recognition":false,"use_seal_recognition":true,"use_ocr_for_image_block":false,"format_block_content":true,"merge_layout_blocks":true,"markdown_ignore_labels":["number","footnote","header","header_image","footer","footer_image","aside_text"],"return_layout_polygon_points":true},"parsing_res_list":[{"block_label":"header_image","block_content":"<div style=\"text-align: center;\"></div>\n","block_bbox":[27,24,176,119],"block_id":0,"group_id":0,"block_polygon_points":[[27.0,24.0],[176.0,24.0],[176.0,119.0],[27.0,119.0]]},{"block_label":"doc_title","block_content":"# | BẢN TIN SÁNG NGÀY 05/05/2026","block_bbox":[186,44,938,94],"block_id":1,"block_order":1,"group_id":1,"block_polygon_points":[[186.0,44.0],[938.0,44.0],[938.0,94.0],[186.0,94.0]]},{"block_label":"paragraph_title","block_content":"#### Tin tức vĩ mô","block_bbox":[16,153,177,181],"block_id":2,"block_order":2,"group_id":2,"block_polygon_points":[[16.0,153.0],[177.0,153.0],[177.0,181.0],[16.0,181.0]]},{"block_label":"text","block_content":"• Hoa Kỳ: Đơn đặt hàng nhà máy tháng 3: +1.5% (Kỳ vọng: +0.5%, Tháng trước: không đổi - đã điều chỉnh thành +0.3%).","block_bbox":[10,188,630,238],"block_id":3,"block_order":3,"group_id":3,"block_polygon_points":[[10.0,188.0],[630.0,188.0],[630.0,238.0],[10.0,238.0]]},{"block_label":"text","block_content":"Hoa Kỳ: Bộ trưởng Tài chính Bessent: Thế giới đang thiếu hụt 8-10 triệu thùng dầu mỗi ngày.","block_bbox":[10,248,629,298],"block_id":4,"block_order":4,"group_id":4,"block_polygon_points":[[10.0,248.0],[629.0,248.0],[629.0,298.0],[10.0,298.0]]},{"block_label":"text","block_content":"UAE cho biết một tàu chở dầu của họ đã bị máy bay không người lái lran tấn công tại Eo biển Hormuz.","block_bbox":[10,307,629,356],"block_id":5,"block_order":5,"group_id":5,"block_polygon_points":[[10.0,307.0],[629.0,307.0],[629.0,356.0],[10.0,356.0]]},{"block_label":"text","block_content":"• Eurozone: Nhà hoạch định chính sách của ECB Każimír, cho biết việc tăng lãi suất vào tháng 6 gần như là điều không thể tránh khỏi do lạm phát từ giá năng lượng. Đồng thời, ngày càng có khả năng châu Âu sẽ phải đối mặt với một giai đoạn dài của lạm phát lan rộng trên nhiều lĩnh vực. Thị trường cũng nhanh chóng phần ánh kỳ vọng này, với xác suất tăng lãi suất 25 bps trong tháng 6 lên khoảng 81%, đồng thời định giá gần 100 điểm cơ bản thất chặt từ nay đến cuối năm.","block_bbox":[8,367,630,537],"block_id":6,"block_order":6,"group_id":6,"block_polygon_points":[[8.0,367.0],[630.0,367.0],[630.0,537.0],[8.0,537.0]]},{"block_label":"text","block_content":"Việt Nam: 4T2026. CPI tháng 4 +5.46%; CPI 4T +3.99% y/y. FDI thực hiện +9.8% y/y; FDI đăng ký +32% y/y. Tổng mức bán lẻ hàng hóa và doanh thu dịch vụ tiêu dùng +11.1% y/y. Xuất khẩu +19.7% y/y; nhập khẩu +28.7% y/y. Thu NSNN +15.2% y/y; chi NSNN +11.6% y/y.","block_bbox":[10,544,631,643],"block_id":7,"block_order":7,"group_id":7,"block_polygon_points":[[10.0,544.0],[631.0,544.0],[631.0,643.0],[10.0,643.0]]},{"block_label":"text","block_content":"Việt Nam: PMI tháng 4/2026 đạt 50.5 điểm (tháng 3 đạt 51.2 điểm). Các nhà sản xuất Việt Nam ghi nhận số lượng đơn đặt hàng mới giảm. Sản lượng tiếp tục tăng, nhưng tốc độ tăng đã chậm lại thành mức thấp của mười tháng.","block_bbox":[10,651,630,750],"block_id":8,"block_order":8,"group_id":8,"block_polygon_points":[[10.0,651.0],[630.0,651.0],[630.0,750.0],[10.0,750.0]]},{"block_label":"text","block_content":"Việt Nam: Tại phiên hợp thường kỳ Chính phủ ngày 4/5, Phó Thủ tướng yêu cầu phải bảo đảm làm sao mức lãi suất cho vay thấp nhất có thể để hỗ trợ tối đa cho doanh nghiệp và nền kinh tế.","block_bbox":[10,758,631,832],"block_id":9,"block_order":9,"group_id":9,"block_polygon_points":[[10.0,758.0],[631.0,758.0],[631.0,832.0],[10.0,832.0]]},{"block_label":"paragraph_title","block_content":"#### Tin tức thị trường","block_bbox":[15,877,231,907],"block_id":10,"block_order":10,"group_id":10,"block_polygon_points":[[15.0,877.0],[231.0,877.0],[231.0,907.0],[15.0,907.0]]},{"block_label":"text","block_content":"Việt Nam: Dòng tiến đang có xu hướng tìm kiếm lợi nhuận ngắn hạn theo KQKD Q1 và triển vọng kinh doanh năm tại mùa Đại hội cổ đông; nhà đầu tư cần nhắc giao dịch nhanh theo biến động ngắn hạn của thị trường.","block_bbox":[13,917,622,1013],"block_id":11,"block_order":11,"group_id":11,"block_polygon_points":[[13.0,917.0],[622.0,917.0],[622.0,1013.0],[13.0,1013.0]]},{"block_label":"text","block_content":"VNX: Ghi nhận kết quả kinh doanh ăn tương, với doanh thu và lợi nhuận đều tăng trên 80% so với cùng kỳ, thực hiện được 26% kế hoạch cả năm.","block_bbox":[14,1020,622,1092],"block_id":12,"block_order":12,"group_id":12,"block_polygon_points":[[14.0,1020.0],[622.0,1020.0],[622.0,1092.0],[14.0,1092.0]]},{"block_label":"text","block_content":"- HAH: BCTC hợp nhất quý 1/2026: doanh thu thuần tăng 8% lên 1.26 nghìn tỷ đồng, trong khi lợi nhuận ròng tăng đến 29% lên 300 tỷ đồng.","block_bbox":[14,1098,622,1149],"block_id":13,"block_order":13,"group_id":13,"block_polygon_points":[[14.0,1098.0],[622.0,1098.0],[622.0,1149.0],[14.0,1149.0]]},{"block_label":"text","block_content":"• VFG: Đặt mục tiêu doanh thu 3,970 tỷ đồng và lợi nhuận sau thuế 365 tỷ đồng trong năm 2026, tương ứng tăng trưởng 8.2% và 6.8%. Công ty dự kiến tiếp tục chi cổ tức tiến mặt, song giảm xuống còn 20%.","block_bbox":[13,1155,622,1227],"block_id":14,"block_order":14,"group_id":14,"block_polygon_points":[[13.0,1155.0],[622.0,1155.0],[622.0,1227.0],[13.0,1227.0]]},{"block_label":"text","block_content":"HAG: Báo lãi hơn 1.1 nghìn tỷ đồng trong quý 1, là mức lãi quý cao nhất từ trước tới nay. Nguyên nhân chủ yếu nhờ được miễn giảm lãi trái phiếu.","block_bbox":[13,1234,623,1306],"block_id":15,"block_order":15,"group_id":15,"block_polygon_points":[[13.0,1234.0],[623.0,1234.0],[623.0,1306.0],[13.0,1306.0]]},{"block_label":"text","block_content":"DPM: Đạt doanh thu thuần hơn 5.6 nghìn tỷ đồng và lãi ròng hơn 400 tỷ đồng, tăng lẫn lượt 36.5% và 96.1% so với cùng kỳ năm trước. Kết quả tích cực đến từ sản lượng tiêu thụ phân bón và hóa chất tăng mạnh, cùng với việc điều chỉnh tăng giá bán bình quân.","block_bbox":[13,1313,623,1410],"block_id":16,"block_order":16,"group_id":16,"block_polygon_points":[[13.0,1313.0],[623.0,1313.0],[623.0,1410.0],[13.0,1410.0]]},{"block_label":"text","block_content":"- DBC: Báo doanh thu đạt hơn 4.1 nghìn tỷ đồng trong quý 1, tăng 14% y/y. Lãi ròng đạt 374 tỷ đồng, thấp hơn cùng kỳ 26%, cũng là quý thứ 2 liên tiếp giảm lãi.","block_bbox":[14,1417,622,1488],"block_id":17,"block_order":17,"group_id":17,"block_polygon_points":[[14.0,1417.0],[622.0,1417.0],[622.0,1488.0],[14.0,1488.0]]},{"block_label":"text","block_content":"- ACV: Quý 1, ACV ghi nhận doanh thu thuần hơn 6.8 nghìn tỷ đồng, tăng gần 8% y/y; lãi ròng hơn 3.3 nghìn tỷ đồng, tăng 7.2% y/y.","block_bbox":[14,1496,622,1546],"block_id":18,"block_order":18,"group_id":18,"block_polygon_points":[[14.0,1496.0],[622.0,1496.0],[622.0,1546.0],[14.0,1546.0]]},{"block_label":"paragraph_title","block_content":"### Thị trường tài chính","block_bbox":[670,169,914,203],"block_id":19,"block_order":19,"group_id":19,"block_polygon_points":[[670.0,169.0],[914.0,169.0],[914.0,203.0],[670.0,203.0]]},{"block_label":"table","block_content":"\n\n<table border=1 style='margin: auto; word-wrap: break-word;'><tr><td style='text-align: center; word-wrap: break-word;'></td><td style='text-align: center; word-wrap: break-word;'>05/05/2026</td><td style='text-align: center; word-wrap: break-word;'>%Ngày</td></tr><tr><td colspan=\"3\">Thị trường chúng khoản</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>S&amp;P500</td><td style='text-align: center; word-wrap: break-word;'>7,200.8</td><td style='text-align: center; word-wrap: break-word;'>+0.87</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>Dow Jones</td><td style='text-align: center; word-wrap: break-word