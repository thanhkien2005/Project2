# =====================
# Project-specific exclusions
# =====================

# Large source PDFs (copyright + ~190MB)
data/*.pdf

# Persistent vector DB (~78MB, rebuild from chunks.jsonl via Embedding+ChromaDB.ipynb)
backend/data/chromadb/
chromadb/

# HF Spaces deploy mirror (duplicate of backend/, ~164MB)
hf-space/

# Backup files
*.bak
*.bak-*
chunks.jsonl.bak-*

# Duplicate root chunks.jsonl (canonical copy is at backend/data/chunks.jsonl)
/chunks.jsonl

# Local test artifacts
src/body.json

